# Variáveis globais da suite de testes (copie para .env.test)
API_BASE_URL=http://localhost:80
JWT_SECRET=test-jwt-secret-totalfretes-suite
INTERNAL_SERVICE_KEY=test-internal-service-key
NODE_ENV=test

# Credenciais de seed para integração
ADMIN_SEED_ENABLED=true
ADMIN_SEED_EMAIL=admin@totalfretes.com.br
ADMIN_SEED_PASSWORD=Admin@123456

# RabbitMQ (management API para asserts de fila)
RABBITMQ_MANAGEMENT_URL=http://localhost:15672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
