# GIT_TOKEN=

# RABBITMQ_DEFAULT_USER=
# RABBITMQ_DEFAULT_PASS=

# ========== Seed demo (somente neste .env raiz — não configure nos .env dos serviços) ==========
# DEMO_DATA_SEED_ENABLED=true — habilita execução da seed demo (script manual e rotas internas)
# DEMO_DATA_SEED_ON_STARTUP=false — padrão; não reexecuta seed demo ao subir containers
# Após subir a stack: npm run seed:demo (uma vez, ou após reset de volumes)
# Imagens de catálogo (tipos de carga): packages/demo-seed-data/assets/cargo-images/ (versionadas)
# Override local opcional: uploads/cargo-images/
# Logos demo (não versionados): uploads/company-images/
# DEMO_SEED_PASSWORD=Empresa@123456
# DEMO_SEED_DRIVER_PASSWORD=Motorista@123456
# INTERNAL_SERVICE_KEY=dev-internal-service-key
