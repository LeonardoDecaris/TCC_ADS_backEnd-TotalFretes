PORT=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# npm run dev na sua máquina: localhost (porta publicada pelo Docker Compose).
# Dentro do Compose, o serviço sobrescreve com rabbitmq — ver docker-compose.yml.
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Opcional — mesmos padrões do authentication-service / README
# EMAIL_EVENTS_EXCHANGE=email.events
# EMAIL_SEND_QUEUE=email.send
# EMAIL_ROUTING_KEY_PASSWORD_RESET=email.send.password_reset
# EMAIL_DLX_EXCHANGE=email.dlx
# EMAIL_SEND_FAILED_QUEUE=email.send.failed
