{
  "name": "storage-service",
  "version": "1.0.0",
  "description": "Microserviço para upload e gerenciamento de arquivos",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node -r @total-fretes/tracing/register dist/index.js",
    "dev": "ts-node -r @total-fretes/tracing/register src/index.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:watch": "jest --watch",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" --fix"
  },
  "dependencies": {
    "@total-fretes/demo-seed-data": "file:../packages/demo-seed-data",
    "@total-fretes/logging": "file:../packages/logging",
    "@total-fretes/tracing": "file:../packages/tracing",
    "@types/amqplib": "^0.10.8",
    "@types/jsonwebtoken": "^9.0.10",
    "amqplib": "^2.0.1",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "mysql2": "^3.9.7",
    "sequelize": "^6.37.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  }
}
