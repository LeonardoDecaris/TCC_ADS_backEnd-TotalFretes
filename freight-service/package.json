{
  "name": "freight-service",
  "version": "1.0.0",
  "description": "Microserviço para gerenciamento de fretes.",
  "main": "dist/index.js",
  "type": "commonjs",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "seed:test": "ts-node src/scripts/runTestSeed.ts",
    "test": "jest --runInBand",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:watch": "jest --watch",
    "lint": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint:fix": "eslint --no-error-on-unmatched-pattern \"src/**/*.ts\" \"test/**/*.ts\" --fix"
  },
  "keywords": [
    "frete",
    "jwt",
    "microservico"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@total-fretes/logging": "file:../packages/logging",
    "amqplib": "^0.10.9",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7",
    "sequelize": "^6.37.7",
    "validation-br": "^1.6.4",
    "validator": "^13.15.26",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.0",
    "@types/opossum": "^8.1.9",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.1",
    "globals": "^16.4.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.2"
  }
}
